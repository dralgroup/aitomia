# ---------------------------------------------------------------------------
# Aitomia configuration.
#
# Copy this file to `aitomia_agents/.env` and fill in your own values:
#
#     cp aitomia_agents/.env.example aitomia_agents/.env
#
# At minimum you must set the three OPENAI_* values to point at an
# OpenAI-compatible chat-completions endpoint (OpenAI, DeepSeek, Alibaba
# DashScope/Qwen, a local vLLM/Ollama server, etc.). The other values below
# have sensible defaults for a local, single-machine run.
# ---------------------------------------------------------------------------

# --- LLM (OpenAI-compatible API) -------------------------------------------
# A *capable* model is required: the agent makes many tool-routing decisions,
# and weak models mis-route (e.g. picking the wrong molecule-retrieval tool).
# The paper used qwen3-max-preview (via Alibaba DashScope, shown below); any
# sufficiently capable OpenAI-compatible model works (GPT-4-class, DeepSeek, …).
OPENAI_MODEL=qwen3-max-preview
# Your API key. NEVER commit a real key. Keep it only in `.env` (git-ignored).
OPENAI_API_KEY=your-api-key-here
# The base URL of the OpenAI-compatible endpoint.
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Execution mode --------------------------------------------------------
# DEV_MODE=True runs calculations locally via MLatom (no external SLURM / file
# microservices). This is the mode used by the open-source CLI example.
DEV_MODE=True

# Directory where calculation output files are written.
RESULT_DIR=./aitomia_results

# --- External microservices (NOT used when DEV_MODE=True) ------------------
# These are placeholders so configuration loads; they are ignored in DEV_MODE.
FILE_SERVICE_URL=http://127.0.0.1:8848
SLURM_SERVICE_URL=http://127.0.0.1:8848

# --- Logging ---------------------------------------------------------------
DEBUG=True
LOG_LEVEL=INFO
LOG_FILE=aitomia_agents.log

# --- Conversation memory ---------------------------------------------------
# Leave MEMORY_SAVER unset to keep chat state in memory (no database needed).
# Set MEMORY_SAVER=postgres and DB_DSN=... to persist to PostgreSQL instead
# (requires the optional `langgraph-checkpoint-postgres` package).
# MEMORY_SAVER=postgres
# DB_DSN=postgresql://postgres:postgres@localhost:5432/postgres
